# Revido Mail — environment variables
#
# This file documents variable NAMES only. Never commit real values here or
# anywhere else — secrets are injected at runtime by Infisical (see
# docs/deploy.md). Locally, copy this to `.env` (gitignored) and fill it in,
# or run services through `infisical run -- <command>`.
#
# Anything prefixed `VITE_` is bundled into the browser build and is
# therefore PUBLIC. Never put a secret behind a `VITE_` name.
#
# The names below are the ones the code ACTUALLY reads (grep `process.env` /
# `import.meta.env`). Keep this file in lock-step with those reads.

# --- Runtime ---------------------------------------------------------------
# Port the API binds to. Railway injects this; falls back to 8787 locally.
PORT=

# --- Database (Railway Postgres 18) -----------------------------------------
# Connection string read by packages/db (getDb) and drizzle-kit migrations.
# NOTE: the role MUST be a superuser or a BYPASSRLS role — the content tables are
# FORCE ROW LEVEL SECURITY, so asService() only bypasses RLS for such a role
# (Railway's default `postgres` role qualifies). See packages/db/src/client.ts.
DATABASE_URL=
# Direct/unpooled connection for migrations on Railway's private network (ops).
DATABASE_INTERNAL_URL=

# --- Better Auth (sessions + social OAuth) ----------------------------------
# Session/token signing secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=
# Public base URL of the API. The OAuth callback + the image-proxy base are
# DERIVED from this (`${BETTER_AUTH_URL}/auth/oauth/:provider/callback`), so there
# is no separate *_OAUTH_REDIRECT_URI var. e.g. https://api.staging.revido.co
BETTER_AUTH_URL=
# Where the API redirects the browser after a mailbox is connected (the web app).
WEB_ORIGIN=

# --- Browser-public (Vite, apps/web) ----------------------------------------
# The API base the hc client calls. Keep in sync with BETTER_AUTH_URL.
VITE_API_URL=
# Content-free PostHog analytics. Unset ⇒ analytics is a complete no-op (no SDK
# init, no network). Autocapture/session-recording are OFF and only a fixed
# allowlist of metadata-only events is sent — never message content.
VITE_POSTHOG_KEY=
# Optional PostHog host (defaults to https://us.i.posthog.com).
VITE_POSTHOG_HOST=

# --- Worker (apps/worker) ---------------------------------------------------
# Optional worker identity + poll cadence; both have safe defaults.
WORKER_ID=
WORKER_POLL_INTERVAL_MS=

# --- LLM backend (OpenRouter) -----------------------------------------------
# The LLM backend is OpenRouter (OpenAI chat-completions format) — the sole
# backend, for dev and prod alike. It gives per-request model choice across
# providers plus per-request privacy enforcement. Required for any LLM path
# (tests use an injected fake, so the CI gate does not need it).
#
# The OpenRouter API key and backend selector.
OPENROUTER_API_KEY=
# Per-request no-training / ZDR enforcement. Defaults to ON — only the literal
# string `false` disables it. Leave unset (or `true`) to keep sending
# `provider.zdr` + `data_collection: 'deny'` on every request.
OPENROUTER_ENFORCE_ZDR=
# Per-tier OpenRouter model slugs. Editing one retargets that tier to ANY
# OpenRouter model — no code change. Cost-conscious defaults when unset:
# TRIAGE=openai/gpt-5-nano, SUMMARY=openai/gpt-5-nano,
# ESCALATION=openai/gpt-5-mini.
LLM_MODEL_TRIAGE=
LLM_MODEL_SUMMARY=
LLM_MODEL_ESCALATION=
# OpenRouter has no Batches API — set this to `true` so backfill triage uses the
# real-time path. Read by apps/worker/src/context.ts (isBatchTriageEnabled).
ANTHROPIC_BATCHES_DISABLED=

# --- KMS (credential envelope encryption) ------------------------------------
# The only wired provider today is the dev KMS (DevKmsProvider). A real AWS KMS
# provider is not wired yet — no AWS_KMS_* vars are read by the code.
DEV_KMS_MASTER_KEY=

# --- Attachment object storage -----------------------------------------------
# Attachments <=10MB are stored inline (encrypted in the DB). Larger ones go to a
# StorageProvider. The wired dev impl is local-filesystem; the S3/R2 impl is a
# stub swap point (set STORAGE_S3_BUCKET to select it once implemented).
STORAGE_LOCAL_DIR=
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=
STORAGE_S3_ENDPOINT=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=

# --- Google OAuth + Gmail Pub/Sub (Gmail sync + push webhook) ----------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Pub/Sub topic the worker registers the Gmail watch against.
GMAIL_PUBSUB_TOPIC=
# Expected `aud` claim on the push OIDC token (the /webhooks/gmail endpoint URL).
# REQUIRED in production — the webhook is refused (500) if unset there.
GMAIL_PUSH_AUDIENCE=
# Expected push service-account email on the OIDC token. REQUIRED in production.
GMAIL_PUSH_SA_EMAIL=

# --- Microsoft Graph (Outlook sync + push webhook) --------------------------
# NB: the API's social-login path reads MS_*, while the worker's Graph SYNC
# adapter reads MICROSOFT_* / GRAPH_*. Set both (to the same app registration).
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Public URL Graph posts change notifications to (the /webhooks/graph endpoint).
GRAPH_NOTIFICATION_URL=
# Subscription shared secret echoed back as `clientState` on each notification.
# REQUIRED in production — the webhook is refused (500) if unset there.
GRAPH_CLIENT_STATE=

# --- Embeddings ---------------------------------------------------------------
VOYAGE_API_KEY=
OPENAI_API_KEY=

# --- Email (outbound, digests) -----------------------------------------------
RESEND_API_KEY=
DIGEST_FROM=

# --- Leads --------------------------------------------------------------------
LEAD_NOTIFY_WEBHOOK_URL=

# --- Infisical (secret injection) ---------------------------------------------
INFISICAL_TOKEN=
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=
