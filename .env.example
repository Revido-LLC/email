# Revido Mail — environment variables
#
# This file documents variable NAMES only. Never commit real values here or
# anywhere else — secrets are injected at runtime by Infisical (see
# docs/deploy.md). Locally, copy this to `.env` (gitignored) and fill it in,
# or run services through `infisical run -- <command>`.
#
# Anything prefixed `VITE_` is bundled into the browser build and is
# therefore PUBLIC. Never put a secret behind a `VITE_` name.

# --- Runtime ---------------------------------------------------------------
# Port each service binds to. Railway injects this; falls back locally.
PORT=

# --- Database (Railway Postgres 18) -----------------------------------------
# Public pooled connection string (read by packages/db getDb).
DATABASE_URL=
# Direct/unpooled connection for migrations (optional; falls back to DATABASE_URL).
DATABASE_INTERNAL_URL=

# --- Better Auth (sessions + social OAuth) ----------------------------------
# Session/token signing secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=
# Public base URL of the API (OAuth callback origin), e.g. https://api.staging.revido.co
BETTER_AUTH_URL=

# --- Browser-public (Vite, apps/web) ----------------------------------------
# The API base the hc client calls. Keep in sync with BETTER_AUTH_URL.
VITE_API_URL=
VITE_POSTHOG_KEY=

# --- Anthropic ---------------------------------------------------------------
ANTHROPIC_API_KEY=

# --- KMS (credential envelope encryption) ------------------------------------
DEV_KMS_MASTER_KEY=
AWS_KMS_KEY_ID=
AWS_REGION=

# --- Google OAuth + Pub/Sub (Gmail sync) -------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_PUBSUB_TOPIC=
GOOGLE_PUBSUB_VERIFICATION_AUDIENCE=

# --- Microsoft Graph (Outlook sync) ------------------------------------------
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_OAUTH_REDIRECT_URI=
MS_WEBHOOK_CLIENT_STATE=

# --- Embeddings ---------------------------------------------------------------
VOYAGE_API_KEY=
OPENAI_API_KEY=

# --- Email (outbound, digests) -----------------------------------------------
RESEND_API_KEY=
DIGEST_FROM_ADDRESS=

# --- Leads --------------------------------------------------------------------
LEADS_SLACK_WEBHOOK_URL=

# --- Infisical (secret injection) ---------------------------------------------
INFISICAL_TOKEN=
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=
